{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "src/main.tsx",
    "src/App.tsx", 
    "src/types/**/*",
    "src/contexts/**/*",
    "src/hooks/**/*",
    "src/utils/**/*",
    "src/components/**/*",
    "src/pages/**/*",
    "src/shared/scss/**/*"
  ],
  "exclude": [
    "src/app/**/*",
    "src/main.ts",
    "src/test.ts"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
