{
    "name": "react-hnpwa",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"src/**/*.{ts,tsx,scss,json}\"",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "dependencies": {
        "@tanstack/react-query": "^5.62.0",
        "dompurify": "^3.2.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-router-dom": "^6.28.0",
        "sass": "^1.82.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.1.0",
        "@types/dompurify": "^3.2.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "^9.15.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-react-hooks": "^5.0.0",
        "eslint-plugin-react-refresh": "^0.4.15",
        "globals": "^15.12.0",
        "jsdom": "^25.0.1",
        "prettier": "^3.4.2",
        "typescript": "~5.7.0",
        "typescript-eslint": "^8.15.0",
        "vite": "^6.0.0",
        "vite-plugin-pwa": "^0.21.1",
        "vitest": "^2.1.8",
        "@playwright/test": "^1.49.0"
    },
    "prettier": {
        "trailingComma": "es5",
        "tabWidth": 4,
        "singleQuote": true,
        "printWidth": 120
    }
}
